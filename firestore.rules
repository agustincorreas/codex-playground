rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Catálogo: lectura pública (la app busca con autocompletado),
    // escritura solo desde scripts con Admin SDK.
    match /perfumes/{perfumeId} {
      allow read: if true;
      allow write: if false;
    }

    // Datos del usuario: solo el dueño.
    match /usuarios/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      // El campo `pro` lo escribe solo el webhook de RevenueCat (Admin SDK).
      allow write: if false;

      match /historial/{busquedaId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /guardados/{perfumeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Búsquedas y contadores: solo Cloud Functions (Admin SDK).
    match /busquedas/{busquedaId} {
      allow read, write: if false;
    }
    match /limites/{docId} {
      allow read, write: if false;
    }
  }
}
